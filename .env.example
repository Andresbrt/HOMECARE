# =============================================================================
# HOMECARE — Variables de entorno requeridas
# Copia este archivo como .env y llena los valores ANTES de correr Docker
# NUNCA commitees el archivo .env — ya está en .gitignore
# =============================================================================

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=homecare_db
DATABASE_USERNAME=homecare_user
DATABASE_PASSWORD=CAMBIA_ESTE_PASSWORD_POR_UNO_SEGURO

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIA_ESTE_PASSWORD_REDIS

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 64
JWT_SECRET=GENERA_UN_SECRETO_DE_MINIMO_64_CARACTERES_AQUI
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── Firebase ──────────────────────────────────────────────────────────────────
# FIREBASE_CREDENTIALS_JSON: pega el contenido COMPLETO del JSON de service account
# (Firebase Console → Project Settings → Service Accounts → Generate new private key)
# Ejemplo: {"type":"service_account","project_id":"homecare-xxx",...}
FIREBASE_CREDENTIALS_JSON=PEGA_AQUI_EL_JSON_COMPLETO_DEL_SERVICE_ACCOUNT

# Firebase Cloud Messaging server key (Firebase Console → Project Settings → Cloud Messaging)
FIREBASE_SERVER_KEY=AAAA...tu_server_key

# ── Wompi Pagos ───────────────────────────────────────────────────────────────
# Obtén tus llaves en https://comercios.wompi.co
WOMPI_PUBLIC_KEY=pub_prod_XXXXXXXXXX
WOMPI_PRIVATE_KEY=prv_prod_XXXXXXXXXX
WOMPI_EVENT_SECRET=tu_event_secret_wompi

# URLs de callback (reemplaza con tu dominio en Railway o producción)
PAYMENT_CALLBACK_URL=https://homecare-backend.railway.app/api/payments/callback
PAYMENT_WEBHOOK_URL=https://homecare-backend.railway.app/api/payments/webhook

# ── Google Maps ───────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXX

# ── Email (Gmail con App Password) ───────────────────────────────────────────
# Activa 2FA en Gmail, luego ve a: Cuenta de Google → Seguridad → App passwords
MAIL_USERNAME=tu@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── AWS S3 (almacenamiento de archivos) ───────────────────────────────────────
# Si usas almacenamiento local en vez de S3, puedes dejarlo en blanco
AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=homecare-files
AWS_REGION=us-east-1

# ── Railway (solo para CI/CD) ─────────────────────────────────────────────────
# Obtén el token en: railway.app → Settings → Tokens
RAILWAY_TOKEN=tu_railway_token
# URL pública de tu servicio en Railway (se setea después del primer deploy)
RAILWAY_PUBLIC_URL=https://homecare-backend.railway.app
