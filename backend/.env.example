# ===============================================
# HOMECARE API - Variables de Entorno CRÍTICAS
# ===============================================
# 🚨 NUNCA commitear este archivo con valores reales

# =============================================== 
# 🔐 SEGURIDAD - OBLIGATORIAS
# ===============================================
# JWT Secret - MÍNIMO 32 caracteres, cambiar en producción
JWT_SECRET=your_super_secret_jwt_key_must_be_at_least_32_characters_long_for_security

# ===============================================
# 💳 WOMPI PAGOS - OBLIGATORIAS
# ===============================================
# Claves de Wompi (usar claves de prueba para desarrollo)
WOMPI_PUBLIC_KEY=pub_test_your_public_key_here
WOMPI_PRIVATE_KEY=prv_test_your_private_key_here
WOMPI_EVENT_SECRET=test_your_event_secret_here
WOMPI_API_URL=https://production.wompi.co
WOMPI_PRODUCTION=false

# URL para callbacks de pago (debe ser accesible desde internet)
PAYMENT_CALLBACK_URL=https://your-domain.com

# ===============================================
# 📍 GOOGLE MAPS - OBLIGATORIA
# ===============================================
# API Key de Google Maps (habilitar Directions, Distance Matrix, Geocoding)
GOOGLE_MAPS_API_KEY=AIzaSyDHKUqdqatpOVRZELsSmNrdxVgUS-N5X1U

# ===============================================
# 🔔 FIREBASE - OBLIGATORIA
# ===============================================
# Server Key para notificaciones push
FIREBASE_SERVER_KEY=AAAA_your_firebase_server_key_here
FIREBASE_CREDENTIALS_PATH=classpath:firebase-credentials.json

# ===============================================
# 🗄️ BASE DE DATOS
# ===============================================
DATABASE_URL=jdbc:postgresql://localhost:5432/homecare_db
DATABASE_USERNAME=homecare_user
DATABASE_PASSWORD=secure_password_change_in_production

# ===============================================
# ☁️ AWS S3 - Para archivos (opcional en desarrollo)
# ===============================================
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_S3_BUCKET=homecare-files-dev
AWS_S3_REGION=us-east-1

# ===============================================
# 📧 EMAIL - Para notificaciones
# ===============================================
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password

# ===============================================
# 🌐 APLICACIÓN
# ===============================================
APP_ENVIRONMENT=development
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===============================================
# 📊 CONFIGURACIONES OPCIONALES
# ===============================================
# Tracking
TRACKING_UPDATE_INTERVAL=30
TRACKING_DISTANCE_THRESHOLD=50
TRACKING_ETA_CALCULATION=google

# Files
FILE_MAX_SIZE=10485760
FILE_STORAGE_TYPE=s3

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=100

# Logging
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false