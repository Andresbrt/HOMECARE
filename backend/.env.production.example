# =============================================
# HOMECARE API - PRODUCTION ENVIRONMENT
# =============================================
# IMPORTANTE: Este archivo contiene EJEMPLOS. 
# Reemplaza TODOS los valores con tus credenciales reales.
# NUNCA comitees este archivo a GitHub.

# =============================================
# SPRING PROFILE
# =============================================
SPRING_PROFILES_ACTIVE=production

# =============================================
# DATABASE (PostgreSQL - Neon Serverless)
# =============================================
# Obtén estos valores en: https://console.neon.tech
# Sección: Connection Details -> Connection String

# Opción 1: URL completa (RECOMENDADO)
# Formato: jdbc:postgresql://<host>/<database>?user=<user>&password=<password>&sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-cool-example-123456.us-east-2.aws.neon.tech/neondb?user=neondb_owner&password=YOUR_PASSWORD_HERE&sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=YOUR_PASSWORD_HERE

# Opción 2: Variables separadas (alternativa)
# DATABASE_HOST=ep-cool-example-123456.us-east-2.aws.neon.tech
# DATABASE_PORT=5432
# DATABASE_NAME=neondb
# DATABASE_USERNAME=neondb_owner
# DATABASE_PASSWORD=YOUR_PASSWORD_HERE

# IMPORTANTE para Neon:
# - SIEMPRE usa sslmode=require en la URL
# - El host termina en .neon.tech
# - El usuario suele ser <database>_owner
# - Neon es serverless: no necesitas ajustar pool size

# =============================================
# REDIS (Cache, Rate Limiting, JWT Blacklist)
# =============================================
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_SECURE_REDIS_PASSWORD

# =============================================
# JWT (JSON Web Tokens)
# =============================================
# CRÍTICO: Genera un secret de al menos 64 caracteres
# PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
# Bash: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=REPLACE_WITH_64_CHARACTER_MINIMUM_SECRET_GENERATED_ABOVE
JWT_EXPIRATION=86400000        # 24 horas (en milisegundos)
JWT_REFRESH_EXPIRATION=604800000  # 7 días (en milisegundos)

# =============================================
# CORS (Cross-Origin Resource Sharing)
# =============================================
# Lista separada por comas de dominios permitidos
# NO uses "*" en producción
CORS_ALLOWED_ORIGINS=https://app.homecare.com,https://admin.homecare.com

# =============================================
# WOMPI (Payment Gateway Colombiano)
# =============================================
# Dashboard: https://comercios.wompi.co/
WOMPI_PUBLIC_KEY=pub_prod_XXXXXXXXXXXXXXXXXXXXX
WOMPI_PRIVATE_KEY=prv_prod_XXXXXXXXXXXXXXXXXXXXX
WOMPI_EVENT_SECRET=XXXXXXXXXXXXXXXXXXXXX
PAYMENT_CALLBACK_URL=https://api.homecare.com/api/v1/payments/callback
PAYMENT_WEBHOOK_URL=https://api.homecare.com/api/v1/payments/webhook
COMMISSION_PERCENTAGE=10.0

# =============================================
# GOOGLE MAPS API
# =============================================
# Habilitar: Directions API, Distance Matrix API, Geocoding API, Places API
# Console: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================
# FIREBASE (Push Notifications)
# =============================================
# Obtener de: Firebase Console > Project Settings > Cloud Messaging
FIREBASE_SERVER_KEY=AAAXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_CREDENTIALS_PATH=classpath:firebase-credentials.json

# =============================================
# AWS S3 (File Storage)
# =============================================
# IAM User con permisos: s3:PutObject, s3:GetObject, s3:DeleteObject
AWS_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_S3_BUCKET=homecare-files-production
AWS_REGION=us-east-1

# =============================================
# SMTP (Email)
# =============================================
# Gmail: Usar "App Password" (no tu contraseña personal)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@homecare.com
SMTP_PASSWORD=XXXX_XXXX_XXXX_XXXX

# =============================================
# TRACKING (Ubicación en Tiempo Real)
# =============================================
TRACKING_UPDATE_INTERVAL=30      # Segundos entre actualizaciones
TRACKING_DISTANCE_THRESHOLD=50   # Metros mínimos para actualizar ubicación
TRACKING_HISTORY_DAYS=30         # Días de retención de historial

# =============================================
# RATE LIMITING
# =============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5             # Intentos de login por 15 min
RATE_LIMIT_REGISTER=3          # Registros por hora desde misma IP
RATE_LIMIT_API=100             # Requests por minuto por IP

# =============================================
# SERVER CONFIGURATION
# =============================================
SERVER_PORT=8080

# =============================================
# ASYNC CONFIGURATION
# =============================================
ASYNC_CORE_POOL=5
ASYNC_MAX_POOL=20
ASYNC_QUEUE_CAPACITY=500
NOTIFICATION_POOL=10

# =============================================
# APPLICATION URLS
# =============================================
FRONTEND_URL=https://app.homecare.com
ADMIN_URL=https://admin.homecare.com

# =============================================
# LOGGING (Optional - defaults work)
# =============================================
# LOGGING_LEVEL_ROOT=WARN
# LOGGING_LEVEL_HOMECARE=INFO
