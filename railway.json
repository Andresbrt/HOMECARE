{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && mvn package -DskipTests -B -q"
  },
  "deploy": {
    "startCommand": "cd backend && java -XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -Dspring.profiles.active=production -Djava.security.egd=file:/dev/./urandom -jar target/homecare-backend-*.jar",
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
