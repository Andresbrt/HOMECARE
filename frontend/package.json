{
  "name": "homecare-app",
  "version": "1.0.0",
  "description": "HomeCare - Aplicación móvil para servicios de limpieza doméstica",
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "test": "jest",
    "test:unit": "jest __tests__/unit/",
    "test:integration": "jest __tests__/integration/",
    "test:e2e": "detox test",
    "test:e2e:android": "detox test -c android.debug",
    "test:e2e:ios": "detox test -c ios.debug",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "clean": "cd android && ./gradlew clean && cd ..",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace HomeCareApp.xcworkspace -scheme HomeCareApp -configuration Release archive",
    "build:e2e:android": "detox build -c android.debug",
    "build:e2e:ios": "detox build -c ios.debug"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/drawer": "^7.2.0",
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/stack": "^7.2.0",
    "axios": "^1.7.9",
    "expo": "~55.0.0",
    "expo-build-properties": "~0.15.0",
    "expo-constants": "~17.0.0",
    "expo-dev-client": "~5.0.0",
    "expo-font": "~13.0.0",
    "expo-image": "~2.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "19.2.0",
    "react-hook-form": "^7.54.0",
    "react-native": "0.84.3",
    "react-native-reanimated": "~3.16.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-config": "^1.5.1",
    "react-native-document-picker": "^9.1.1",
    "react-native-flash-message": "^0.4.2",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "~2.22.0",
    "react-native-image-picker": "^7.1.3",
    "react-native-keychain": "^9.0.1",
    "react-native-linear-gradient": "^2.8.4",
    "react-native-maps": "^1.23.0",
    "react-native-modal": "^13.0.2",
    "react-native-paper": "^5.12.6",
    "react-native-permissions": "^4.1.5",
    "react-native-safe-area-context": "~5.2.0",
    "react-native-screens": "~4.6.0",
    "react-native-svg": "~16.1.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@react-native/babel-preset": "^0.84.0",
    "@react-native/eslint-config": "^0.84.0",
    "@react-native/metro-config": "^0.84.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.8.1",
    "@tsconfig/react-native": "^3.0.5",
    "@types/react": "~19.2.0",
    "@types/react-test-renderer": "^19.2.0",
    "babel-jest": "^29.7.0",
    "detox": "^20.27.3",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "0.84.0",
    "prettier": "^3.4.2",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "keywords": [
    "react-native",
    "homecare",
    "cleaning-services",
    "marketplace",
    "mobile-app"
  ],
  "author": "HomeCare Team",
  "license": "ISC",
  "private": true,
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-navigation|@react-native-async-storage|react-native-vector-icons|react-native-maps)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.test.{js,jsx}",
      "!src/index.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "html",
      "text",
      "lcov"
    ]
  }
}
