# ─── Homecare — Overrides para Desarrollo Local ─────────────────────────────
# Copia este archivo como .env.local y ajusta tus IPs / credenciales.
# .env.local está en .gitignore — NUNCA lo subas al repositorio.
#
# Expo lee las variables EXPO_PUBLIC_* automáticamente en el build.
# Las variables no EXPO_PUBLIC_ solo están disponibles en metro/node.

# URL de tu backend corriendo localmente (cambia la IP por la tuya)
EXPO_PUBLIC_API_URL=http://192.168.1.17:8090/api
EXPO_PUBLIC_WS_URL=ws://192.168.1.17:8090/ws

# MercadoPago — pon true solo en desarrollo/testing
EXPO_PUBLIC_MP_SANDBOX=true
EXPO_PUBLIC_MP_PUBLIC_KEY=TEST-2fc07872-5703-43d1-bf4d-485d988c3323

# ─── PRODUCCIÓN ──────────────────────────────────────────────────────────────
# Para producción usa las credenciales reales de:
#   https://www.mercadopago.com.co/developers/panel
# EXPO_PUBLIC_MP_SANDBOX=false
# EXPO_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
